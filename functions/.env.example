# SendGrid Configuration
# Get your API key from https://sendgrid.com/
SENDGRID_API_KEY=SG.your_api_key_here

# Verified sender email (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=press@yourdomain.com

# Stripe monthly Price IDs per tier (NON-secret). Loaded into the Cloud Functions
# runtime at deploy. Use TEST price IDs in development; swap to LIVE at launch —
# no code change needed. Secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET) live
# in Secret Manager: `firebase functions:secrets:set STRIPE_SECRET_KEY`
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ORGANISATION=price_xxx
